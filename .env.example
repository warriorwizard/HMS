# Tarini V6 root environment template.
# Copy values into local .env files as needed. Do not commit real secrets.

TARINI_ENVIRONMENT=local
TARINI_PROJECT_NAME=Tarini V6
TARINI_VERSION=0.1.0

# Local service URLs
TARINI_BACKEND_URL=http://127.0.0.1:8000
TARINI_FRONTEND_URL=http://127.0.0.1:3000

# Local data services
TARINI_DATABASE_URL=postgresql+psycopg://tarini:tarini@127.0.0.1:5432/tarini
TARINI_REDIS_URL=redis://127.0.0.1:6379/0

