# Tarini V6 backend environment template.
# Do not commit real secrets.

TARINI_PROJECT_NAME=Tarini V6
TARINI_SERVICE_NAME=tarini-backend
TARINI_ENVIRONMENT=local
TARINI_VERSION=0.1.0
TARINI_API_PREFIX=/api/v1
TARINI_ENABLE_DOCS=true
TARINI_LOG_LEVEL=INFO

# Local development defaults
TARINI_DATABASE_URL=postgresql+psycopg://tarini:tarini@127.0.0.1:5432/tarini
TARINI_REDIS_URL=redis://127.0.0.1:6379/0
TARINI_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Replace in local .env; never commit real secrets.
TARINI_SECRET_KEY=replace-with-local-secret
TARINI_ACCESS_TOKEN_MINUTES=30
TARINI_REFRESH_TOKEN_DAYS=14
